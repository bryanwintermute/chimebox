#!/usr/bin/env python3
"""chimebox-panic-daemon

Listens to all keyboard-class /dev/input/event* devices and fires
configured action scripts when specific key combos are pressed.

Why kernel-level evdev (vs. xbindkeys / X-layer hotkeys)?

  - SDL2 kiosks (BasiliskII with SDL_VIDEO_X11_XINPUT2=1) read
    keyboard events via XInput2 raw-mode, which bypasses classic
    XGrabKey passive grabs that xbindkeys uses. So keystrokes
    can be silently consumed by the emulator before xbindkeys
    sees them. Reading evdev directly puts us *below* X
    entirely, which means:

    - We see every keystroke regardless of which app has focus.
    - We survive X server hangs (a real failure mode for a
      long-running kiosk).
    - We work even if the kiosk isn't running yet.

This daemon expects to run as root (or any user with read access
to /dev/input/event* and the right to invoke the configured
action scripts). The systemd unit hardens it with
NoNewPrivileges, ProtectSystem=strict, and a tight capability
set (only CAP_KILL is actually needed, since the action scripts
SIGKILL processes).

Configuration is read from /etc/chimebox-panic-daemon.conf
(an INI file) so Ansible's template module can manage it
without touching this script.
"""

from __future__ import annotations

import configparser
import errno
import logging
import logging.handlers
import os
import select
import signal
import subprocess
import sys
import time
from dataclasses import dataclass, field
from typing import Iterable

try:
    from evdev import InputDevice, KeyEvent, categorize, ecodes, list_devices
except ImportError:
    sys.stderr.write(
        "chimebox-panic-daemon: python3-evdev is required "
        "(apt install python3-evdev)\n"
    )
    sys.exit(1)

try:
    import pyudev
except ImportError:
    sys.stderr.write(
        "chimebox-panic-daemon: python3-pyudev is required "
        "(apt install python3-pyudev)\n"
    )
    sys.exit(1)


CONFIG_PATH = "/etc/chimebox-panic-daemon.conf"

# How often to re-scan /dev/input/event* as a safety net for any udev
# event we might have missed. Belt-and-braces; the udev monitor is the
# primary hot-plug path.
RESCAN_INTERVAL_SECONDS = 30.0

# How often to emit a "watching N device(s)" heartbeat line. Makes a
# silent zero-device daemon visible in journalctl.
HEARTBEAT_INTERVAL_SECONDS = 300.0

# When a udev 'add' event fires but the devnode isn't yet openable
# (rare with source='udev', but possible during USB hub re-enumeration),
# retry on these monotonic offsets from the original event. Total
# coverage ~3s; beyond that the periodic rescan handles it.
ADD_RETRY_DELAYS = (0.2, 0.5, 1.0, 2.0)

# Map our friendly modifier names to the set of evdev key codes
# that satisfy them. Either left or right counts.
MODIFIER_GROUPS = {
    "ctrl": {ecodes.KEY_LEFTCTRL, ecodes.KEY_RIGHTCTRL},
    "alt": {ecodes.KEY_LEFTALT, ecodes.KEY_RIGHTALT},
    "shift": {ecodes.KEY_LEFTSHIFT, ecodes.KEY_RIGHTSHIFT},
    "meta": {ecodes.KEY_LEFTMETA, ecodes.KEY_RIGHTMETA},
}


def setup_logging() -> logging.Logger:
    """Send everything to syslog under tag 'chimebox-panic'."""
    logger = logging.getLogger("chimebox-panic")
    logger.setLevel(logging.INFO)

    handler = logging.handlers.SysLogHandler(address="/dev/log")
    formatter = logging.Formatter("chimebox-panic: %(message)s")
    handler.setFormatter(formatter)
    logger.addHandler(handler)

    # Also echo to stderr when running interactively (systemd
    # journal will capture this on a non-tty too).
    stderr_handler = logging.StreamHandler(sys.stderr)
    stderr_handler.setFormatter(logging.Formatter(
        "%(asctime)s chimebox-panic: %(message)s"
    ))
    logger.addHandler(stderr_handler)

    return logger


log = setup_logging()


@dataclass
class Combo:
    """A configured key combination that fires an action script."""
    name: str
    modifier_groups: list[str]   # e.g. ["ctrl", "alt", "shift"]
    trigger_key_code: int        # e.g. ecodes.KEY_R
    hold_seconds: float          # how long modifiers must be held
    action: str                  # absolute path to the script

    def required_modifier_codes(self) -> list[set[int]]:
        """Returns a list of "any-of" sets, one per modifier group."""
        return [MODIFIER_GROUPS[g] for g in self.modifier_groups]


def parse_combos(config: configparser.ConfigParser) -> list[Combo]:
    """Read [combo:NAME] sections from the config file."""
    combos: list[Combo] = []
    for section in config.sections():
        if not section.startswith("combo:"):
            continue
        name = section.split(":", 1)[1]
        mods = [m.strip().lower() for m in
                config.get(section, "modifiers").split(",") if m.strip()]
        unknown = [m for m in mods if m not in MODIFIER_GROUPS]
        if unknown:
            log.warning("combo '%s' references unknown modifiers: %s",
                        name, unknown)
            continue
        trigger_name = config.get(section, "trigger").strip().lower()
        # evdev's ecodes uses uppercase like KEY_R.
        key_attr = "KEY_" + trigger_name.upper()
        trigger_code = getattr(ecodes, key_attr, None)
        if trigger_code is None:
            log.warning("combo '%s' has unknown trigger key '%s'",
                        name, trigger_name)
            continue
        action = config.get(section, "action").strip()
        if not os.path.isabs(action):
            log.warning("combo '%s' action '%s' is not an absolute path",
                        name, action)
            continue
        if not os.access(action, os.X_OK):
            log.warning("combo '%s' action '%s' is not executable",
                        name, action)
            continue
        hold = config.getfloat(section, "hold_seconds", fallback=0.0)
        combos.append(Combo(
            name=name,
            modifier_groups=mods,
            trigger_key_code=trigger_code,
            hold_seconds=hold,
            action=action,
        ))
    return combos


def is_keyboard_device(d: InputDevice) -> bool:
    """Return True if the device looks like a keyboard.

    We filter on alpha-key presence to skip power buttons, lid
    switches, HDMI hotplug pseudo-keyboards, etc. Use either KEY_R or
    KEY_A so we tolerate the (rare) keyboard that's missing one.
    """
    try:
        caps = d.capabilities()
    except OSError:
        return False
    keys = caps.get(ecodes.EV_KEY, [])
    return ecodes.KEY_R in keys or ecodes.KEY_A in keys


def open_keyboard(path: str) -> InputDevice | None:
    """Open path as an InputDevice if it's a keyboard, else None.

    Closes the device on filter-miss so we don't leak fds during
    periodic rescans. Returns None on any open / permission / filter
    failure; the caller decides whether to retry.
    """
    try:
        d = InputDevice(path)
    except (PermissionError, OSError) as exc:
        log.debug("open %s failed: %s", path, exc)
        return None
    if not is_keyboard_device(d):
        log.debug("ignoring %s (%s) -- no alpha keys", d.path, d.name)
        try:
            d.close()
        except Exception:
            pass
        return None
    return d


def scan_keyboard_paths() -> list[str]:
    """Return all /dev/input/event* paths visible to us. Doesn't
    open them; cheap to call every rescan tick."""
    return [p for p in list_devices() if p.startswith("/dev/input/event")]


@dataclass
class ModifierState:
    """Tracks which modifier-group keys are currently held, when each
    group's hold started, and which combos have already fired for the
    current press of each trigger key."""
    held: set[int] = field(default_factory=set)
    held_since: dict[str, float] = field(default_factory=dict)
    # trigger key_code -> set of combo names that have already fired
    # since this trigger's last press transition. Cleared on release
    # so a fresh press can fire the combo again.
    fired_for_trigger: dict[int, set[str]] = field(default_factory=dict)

    def update(self, key_code: int, value: int) -> None:
        if value == 1:
            # press
            self.held.add(key_code)
            # Fresh press: any prior fired-marker for this key is stale.
            self.fired_for_trigger.pop(key_code, None)
        elif value == 0:
            # release
            self.held.discard(key_code)
            self.fired_for_trigger.pop(key_code, None)
        elif value == 2:
            # autorepeat. The kernel only emits this for keys it
            # currently believes are physically held. Add to held so
            # we can recover modifier state after a state.clear() (as
            # triggered by a hot-unplug -- see remove_path). Doesn't
            # disrupt hold_seconds: setdefault keeps the earliest
            # observed hold-start timestamp per group.
            self.held.add(key_code)

        # Recompute held_since per group.
        for group_name, codes in MODIFIER_GROUPS.items():
            if codes & self.held:
                self.held_since.setdefault(group_name, time.monotonic())
            else:
                self.held_since.pop(group_name, None)

    def has_fired(self, trigger_code: int, combo_name: str) -> bool:
        return combo_name in self.fired_for_trigger.get(trigger_code, set())

    def mark_fired(self, trigger_code: int, combo_name: str) -> None:
        self.fired_for_trigger.setdefault(trigger_code, set()).add(combo_name)

    def all_held(self, group_names: Iterable[str]) -> bool:
        return all(MODIFIER_GROUPS[g] & self.held for g in group_names)

    def held_for(self, group_names: Iterable[str]) -> float:
        """Returns the *minimum* hold duration across the requested
        groups, or 0 if any group is not currently held."""
        if not self.all_held(group_names):
            return 0.0
        starts = [self.held_since[g] for g in group_names
                  if g in self.held_since]
        if not starts:
            return 0.0
        return time.monotonic() - max(starts)

    def clear(self) -> None:
        """Forget all in-flight modifier state. Called when a watched
        device disappears: we have no way to ever see the release
        events for any keys that were held on that device, so without
        clearing we'd carry ghost modifiers forever. After clear, a
        combo can only fire from fresh press events on a still-present
        (or newly-appeared) device, which is exactly the safe default."""
        self.held.clear()
        self.held_since.clear()
        self.fired_for_trigger.clear()


def fire_action(combo: Combo) -> None:
    log.info("combo '%s' fired -> %s", combo.name, combo.action)
    try:
        subprocess.Popen([combo.action], close_fds=True)
    except OSError as exc:
        log.error("failed to invoke '%s': %s", combo.action, exc)


def event_loop(combos: list[Combo]) -> None:
    if not combos:
        log.error("no valid combos configured; daemon will idle")
        while True:
            time.sleep(60)

    # Start the udev monitor BEFORE the initial scan so we don't lose
    # any 'add' events that happen between scan and monitor-start.
    # source='udev' (the pyudev default) means events fire AFTER udevd
    # has applied its rules, including permission/symlink settle, so
    # the devnode is almost always immediately openable.
    udev_context = pyudev.Context()
    monitor = pyudev.Monitor.from_netlink(udev_context, source="udev")
    monitor.filter_by("input")
    monitor.start()

    state = ModifierState()

    # path is the primary key. fd is derived. We never trust fd
    # identity for dedup because the kernel reuses fd numbers across
    # device disappear/reappear cycles.
    path_to_device: dict[str, InputDevice] = {}
    # path -> next-retry monotonic deadline; the int is the attempt
    # index into ADD_RETRY_DELAYS (so we don't retry forever).
    pending_adds: dict[str, tuple[int, float]] = {}

    def add_path(path: str) -> None:
        """Try to add path to the watch set. On open failure, schedule
        a retry via pending_adds. On filter-miss, mark as permanently
        ignored by NOT scheduling a retry."""
        if path in path_to_device:
            return
        d = open_keyboard(path)
        if d is None:
            # Could be transient (permissions still being applied) or
            # permanent (not a keyboard, e.g. mouse/joystick/HDMI).
            # We schedule a retry up to ADD_RETRY_DELAYS; the periodic
            # rescan will eventually re-attempt anyway.
            attempt, _ = pending_adds.get(path, (0, 0.0))
            if attempt < len(ADD_RETRY_DELAYS):
                deadline = time.monotonic() + ADD_RETRY_DELAYS[attempt]
                pending_adds[path] = (attempt + 1, deadline)
                log.debug("deferring add of %s (attempt %d/%d)",
                          path, attempt + 1, len(ADD_RETRY_DELAYS))
            else:
                pending_adds.pop(path, None)
                log.debug("giving up on %s after %d attempts",
                          path, len(ADD_RETRY_DELAYS))
            return
        path_to_device[path] = d
        pending_adds.pop(path, None)
        log.info("watching keyboard: %s (%s)", d.path, d.name)

    def remove_path(path: str) -> None:
        """Drop path from the watch set. Idempotent; safe to call
        even if path is no longer tracked. Clears modifier state to
        avoid ghost-held keys (no release events will ever arrive
        from a vanished device)."""
        d = path_to_device.pop(path, None)
        if d is None:
            pending_adds.pop(path, None)
            return
        try:
            d.close()
        except Exception:
            pass
        log.info("stopped watching: %s", path)
        # Critical: clear all in-flight modifier state. Otherwise a
        # kid who was holding Ctrl+Alt+Shift+R when their keyboard
        # disconnected would have ghost modifiers stuck "down" until
        # daemon restart, and the next keyboard could fire combos
        # from a single trigger key press.
        state.clear()

    def log_watch_summary(prefix: str) -> None:
        if not path_to_device:
            log.warning("%s: watching 0 device(s) -- hotkeys will not "
                        "fire until a keyboard is plugged in", prefix)
            return
        summary = ", ".join(
            f"{os.path.basename(p)}={d.name}"
            for p, d in sorted(path_to_device.items())
        )
        log.info("%s: watching %d device(s): %s",
                 prefix, len(path_to_device), summary)

    def rescan() -> None:
        """Safety net: enumerate /dev/input/event* and add any
        keyboards we're not yet watching. Cheap; covers any udev
        event we may have missed (rare but possible during USB hub
        re-enumeration storms)."""
        seen = set(scan_keyboard_paths())
        # Drop paths that no longer exist (e.g., we missed a 'remove').
        stale = [p for p in path_to_device if p not in seen]
        for p in stale:
            log.info("rescan: %s disappeared (no udev event seen)", p)
            remove_path(p)
        # Add paths that have appeared.
        for p in sorted(seen):
            if p not in path_to_device:
                add_path(p)

    # Seed with whatever's plugged in right now, then drain any udev
    # events that fired during the monitor.start() -> rescan() window.
    rescan()
    drain_udev_events(monitor, add_path, remove_path)
    log_watch_summary("startup")

    next_rescan_at = time.monotonic() + RESCAN_INTERVAL_SECONDS
    next_heartbeat_at = time.monotonic() + HEARTBEAT_INTERVAL_SECONDS
    last_summary_signature: tuple[str, ...] = tuple(sorted(path_to_device))

    while True:
        now = time.monotonic()
        # Deadline-driven timeout: select() must return by the soonest
        # of (next rescan, next heartbeat, next pending-add retry).
        # Otherwise a noisy device's reads could keep select() returning
        # before our 30s rescan deadline ever elapses.
        deadlines = [next_rescan_at, next_heartbeat_at]
        deadlines.extend(t for _, t in pending_adds.values())
        timeout = max(0.0, min(deadlines) - now)

        watch_fds = [monitor.fileno()]
        watch_fds.extend(d.fd for d in path_to_device.values())

        try:
            r, _, _ = select.select(watch_fds, [], [], timeout)
        except OSError as exc:
            if exc.errno == errno.EINTR:
                continue
            raise

        # 1. Process udev hot-plug events first so newly-added
        #    keyboards can contribute press events in this same tick.
        if monitor.fileno() in r:
            drain_udev_events(monitor, add_path, remove_path)

        # 2. Process key events from currently-watched devices. Iterate
        #    a snapshot of the fd list because remove_path mutates it.
        for fd in list(r):
            if fd == monitor.fileno():
                continue
            # Look up device by fd. If the device was just removed via
            # a udev event in step 1, skip silently.
            device = next((d for d in path_to_device.values() if d.fd == fd),
                          None)
            if device is None:
                continue
            try:
                events = list(device.read())
            except OSError as exc:
                if exc.errno in (errno.ENODEV, errno.EBADF):
                    log.warning("device %s went away mid-read", device.path)
                    remove_path(device.path)
                    continue
                raise
            for ev in events:
                if ev.type != ecodes.EV_KEY:
                    continue
                process_key_event(ev.code, ev.value, state, combos)

        # 3. Service deadline-driven timers.
        now = time.monotonic()

        # Retry deferred adds whose deadline has passed.
        ready_retries = [p for p, (_, t) in pending_adds.items() if t <= now]
        for path in ready_retries:
            add_path(path)

        if now >= next_rescan_at:
            rescan()
            next_rescan_at = now + RESCAN_INTERVAL_SECONDS

        # Log on watch-set change OR heartbeat tick.
        cur_signature = tuple(sorted(path_to_device))
        if cur_signature != last_summary_signature:
            log_watch_summary("change")
            last_summary_signature = cur_signature
        elif now >= next_heartbeat_at:
            log_watch_summary("heartbeat")
            next_heartbeat_at = now + HEARTBEAT_INTERVAL_SECONDS


def drain_udev_events(monitor, add_path, remove_path) -> None:
    """Read all currently-pending events from the udev monitor
    without blocking. monitor.poll(0) returns the next event or None
    if the queue is empty."""
    while True:
        event = monitor.poll(timeout=0)
        if event is None:
            return
        action = event.action
        devnode = event.device_node
        if devnode is None or not devnode.startswith("/dev/input/event"):
            continue
        if action == "add":
            add_path(devnode)
        elif action == "remove":
            remove_path(devnode)
        # 'change', 'bind', 'unbind', etc. are ignored.


def process_key_event(key_code: int, value: int, state: "ModifierState",
                      combos: list[Combo]) -> None:
    state.update(key_code, value)
    # Fire combos on the trigger's press (value=1) OR while it's
    # still held (autorepeat, value=2). The autorepeat path is what
    # makes hold_seconds work naturally when the user mashes all
    # keys at once: the combo fires as soon as the modifiers have
    # been held long enough, even if the trigger went down before
    # the threshold elapsed. We use state.fired_for_trigger to ensure
    # a single press fires each combo at most once.
    if value not in (1, 2):
        return
    for combo in combos:
        if key_code != combo.trigger_key_code:
            continue
        if state.has_fired(key_code, combo.name):
            continue
        if not state.all_held(combo.modifier_groups):
            continue
        if combo.hold_seconds > 0:
            if state.held_for(combo.modifier_groups) < combo.hold_seconds:
                log.debug("combo '%s' modifiers held only %.2fs (need %.2fs)",
                          combo.name,
                          state.held_for(combo.modifier_groups),
                          combo.hold_seconds)
                continue
        fire_action(combo)
        state.mark_fired(key_code, combo.name)


def main() -> int:
    config = configparser.ConfigParser()
    if not config.read(CONFIG_PATH):
        log.error("config file %s not found", CONFIG_PATH)
        return 1

    combos = parse_combos(config)
    log.info("parsed %d combo(s)", len(combos))
    for c in combos:
        log.info("  combo '%s': %s + KEY_%s -> %s (hold=%.2fs)",
                 c.name, "+".join(c.modifier_groups),
                 ecodes.keys[c.trigger_key_code].replace("KEY_", ""),
                 c.action, c.hold_seconds)

    # Cleanly exit on SIGTERM / SIGINT so systemd stops us nicely.
    def _shutdown(signum, _frame):
        log.info("got signal %d; exiting", signum)
        sys.exit(0)
    signal.signal(signal.SIGTERM, _shutdown)
    signal.signal(signal.SIGINT, _shutdown)

    try:
        event_loop(combos)
    except Exception:
        log.exception("fatal error in event loop")
        return 2
    return 0


if __name__ == "__main__":
    sys.exit(main())
