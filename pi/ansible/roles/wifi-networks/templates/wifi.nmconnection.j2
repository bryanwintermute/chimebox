# {{ ansible_managed }}
# chimebox wifi network profile (managed by the wifi-networks role).
# Reliability tuning (powersave off, infinite autoconnect-retries) is
# applied globally by the wifi-tuning role's NetworkManager conf.d
# drop-in, so it is intentionally not repeated here.
[connection]
id=chimebox-{{ item.ssid }}
uuid={{ item.ssid | to_uuid }}
type=wifi
autoconnect=true
autoconnect-priority={{ item.priority | default(0) }}

[wifi]
mode=infrastructure
ssid={{ item.ssid }}
{% if item.hidden | default(false) %}
hidden=true
{% endif %}
{% set _band = item.band | default(chimebox_wifi_band) | default('') %}
{% if _band %}
band={{ _band }}
{% endif %}

[wifi-security]
# key-mgmt: wpa-psk (WPA2, default) or sae (WPA3-Personal). SAE mandates
# Protected Management Frames, so we emit pmf=3 (required) with it -- NM
# silently drops the whole keyfile if sae is paired with pmf=optional(2).
key-mgmt={{ item.key_mgmt | default('wpa-psk') }}
{% if (item.key_mgmt | default('wpa-psk')) == 'sae' %}
pmf=3
{% endif %}
psk={{ item.psk }}

[ipv4]
method=auto

[ipv6]
method=auto
