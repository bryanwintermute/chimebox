# {{ ansible_managed }}
# chimebox wifi network profile (managed by the wifi-networks role).
# Reliability tuning (powersave off, infinite autoconnect-retries) is
# applied globally by the wifi-tuning role's NetworkManager conf.d
# drop-in, so it is intentionally not repeated here.
[connection]
id=chimebox-{{ item.ssid }}
uuid={{ item.ssid | to_uuid }}
type=wifi
autoconnect=true
autoconnect-priority={{ item.priority | default(0) }}

[wifi]
mode=infrastructure
ssid={{ item.ssid }}
{% if item.hidden | default(false) %}
hidden=true
{% endif %}

[wifi-security]
key-mgmt=wpa-psk
psk={{ item.psk }}

[ipv4]
method=auto

[ipv6]
method=auto
