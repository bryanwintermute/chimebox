#!/bin/bash
# {{ ansible_managed }}
# chimebox start.sh -- invoked from ~/.xinitrc as the only X client.
#
# All BasiliskII config (ROM, disks, screen, RAM, model, etc.) lives in
# ~/.config/BasiliskII/prefs (managed by Ansible, see
# roles/chimebox/templates/basiliskii-prefs.j2). We just sanity-check
# that the required files exist and prep the X session before invoking
# BasiliskII.

set -u

LOG_DIR="{{ chimebox_logs_dir }}"
mkdir -p "${LOG_DIR}"
LOG_FILE="${LOG_DIR}/basiliskii-$(date +%Y%m%d-%H%M%S).log"

# Disk paths -- must match the prefs file
ROM="{{ chimebox_runtime_dir }}/{{ chimebox_rom_filename }}"
SYSTEM_DISK="{{ chimebox_runtime_dir }}/{{ chimebox_system_disk_filename }}"

# ROM and System disk are required.
for f in "${ROM}" "${SYSTEM_DISK}"; do
    if [ ! -f "${f}" ]; then
        msg="chimebox: required file missing: ${f}"
        echo "${msg}" >&2
        echo "${msg}" >> "${LOG_FILE}"
        # Sleep then exit so systemd/xinit doesn't tight-loop.
        sleep 30
        exit 1
    fi
done

# Force the X display to a sensible mode. Pi 5 + 4K monitor will negotiate
# 4K by default via EDID, which is overkill for emulator workloads and
# makes the BasiliskII window look tiny. Pin to the size in
# chimebox_x_display_width x chimebox_x_display_height (see
# group_vars/all.yml for the three common profiles).
target_mode="{{ chimebox_x_display_width }}x{{ chimebox_x_display_height }}"
connected_output=$(xrandr 2>/dev/null | awk '/ connected/ {print $1; exit}')
if [ -n "${connected_output}" ]; then
    if xrandr --output "${connected_output}" --mode "${target_mode}" \
            >> "${LOG_FILE}" 2>&1; then
        echo "chimebox: set ${connected_output} to ${target_mode}" \
            >> "${LOG_FILE}"
    else
        echo "chimebox: xrandr failed for ${connected_output} ${target_mode};" \
             "leaving display as-is" >> "${LOG_FILE}"
    fi
else
    echo "chimebox: no connected output found via xrandr" >> "${LOG_FILE}"
fi

# Disable host pointer acceleration. With acceleration on, small physical
# mouse movements get amplified by X before BasiliskII sees them, making
# the emulated Mac cursor stutter. We want a 1:1 mapping.
xset m 0 0 >> "${LOG_FILE}" 2>&1 || true

# Hide the host (X) cursor; Basilisk II draws the Mac cursor.
# Use unclutter-xfixes (NOT classic unclutter): the classic version
# polls X and calls XDefineCursor on root windows, which interferes
# with SDL2's pointer-event subscription and breaks remote-pointer
# setups (PiKVM, VNC) -- motion events stop reaching the emulator
# unless a button is held. unclutter-xfixes uses the XFixes extension
# passively and doesn't have that issue.
unclutter-xfixes --hide-on-touch &

# Tiny window manager for proper SDL2 focus handling. Without a WM,
# SDL windows can have weird focus semantics; matchbox-window-manager
# is the canonical kiosk WM (~5MB, no UI of its own).
matchbox-window-manager -use_titlebar no -use_cursor no &
sleep 1  # let it claim WM ownership before B2 starts

# Note: the recovery-keystroke role used to start xbindkeys here.
# That path was superseded by the panic-button role's evdev daemon
# (a system service, not an X-session client). See
# docs/v2-panic-button-design.md for the architectural rationale.

# Disable screen blanking/DPMS.
xset s off
xset -dpms
xset s noblank

# SDL2 hints for remote-pointer compatibility (PiKVM, VNC, tablets):
# - SDL_MOUSE_FOCUS_CLICKTHROUGH: deliver clicks to the SDL window even
#   when it doesn't have host pointer focus. Helps when there's no WM
#   doing focus-follows-mouse.
# - SDL_VIDEO_X11_XINPUT2: prefer the XInput2 protocol for pointer
#   events. (Already default in modern SDL2 but safe to be explicit.)
# - SDL_GRAB_KEYBOARD=0 / SDL_HINT_KEYBOARD_GRAB=0: do NOT call
#   XGrabKeyboard for exclusive keyboard input. SDL's default
#   fullscreen behavior is to grab the keyboard, which preempts
#   xbindkeys' XGrabKey root-grab and breaks the recovery
#   keystroke (Ctrl+Alt+Shift+R force-reset). For a kiosk where
#   the only X client is BasiliskII anyway, there's no other window
#   that could "steal" keys -- the grab gives nothing, and costs
#   the panic button. Always disable.
export SDL_MOUSE_FOCUS_CLICKTHROUGH=1
export SDL_VIDEO_X11_XINPUT2=1
export SDL_GRAB_KEYBOARD=0
export SDL_HINT_KEYBOARD_GRAB=0

# Center the Basilisk II window inside the X canvas. Only meaningful when
# the emulator's screen size is smaller than the X display (e.g. a 4:3
# 1440x1080 emulator inside a 16:9 1920x1080 X canvas, with pillarbox
# black bars on the left and right). Without this, SDL pins the window
# top-left and the bars all end up on the right.
{% if chimebox_center_window %}
export SDL_VIDEO_CENTERED=1
{% endif %}

# Run BasiliskII in a supervised loop. X stays up across Mac OS 8.1
# 'Special > Shut Down' (which causes BasiliskII to exit cleanly), so
# the user sees a brief black screen and then BasiliskII reboots in
# place -- no X teardown, no autologin / startx flicker.
#
# Crash-loop protection: if BasiliskII exits in less than
# CRASH_THRESHOLD_SEC, we treat it as a failure and back off
# exponentially up to a cap. After MAX_FAST_FAILS short runs in a
# row we exit so xinit can fall back to the autologin -> getty path
# (which at least leaves the operator a tty to debug from).
#
# Bedtime sentinel: when /run/chimebox-bedtime exists, we idle without
# running BasiliskII. scripts/bedtime.sh arms this so the kid's
# in-emulator Shut Down click during the warning period doesn't get
# papered over by the supervisor respawning. wake-up.sh / phase 3 of
# bedtime.sh remove the sentinel.
#
# The exit-code is intentionally NOT used to discriminate "deliberate
# Mac shutdown" from "BasiliskII fatal error" -- BasiliskII calls
# exit(0) from many fatal paths too. The rollback-on-shutdown
# behavior (chimebox_shutdown_action: restart-with-rollback) is
# planned for v2 once we have (a) a factory.dsk baseline and (b) a
# discriminator we trust.
#
# Per chimebox_shutdown_action ({{ chimebox_shutdown_action | default('restart') }}):
#   restart -- v1 default; smooth in-place restart loop (this script).
{# Future v2 will branch on chimebox_shutdown_action; for now only
   'restart' is implemented and any other value falls through to it. #}

CRASH_THRESHOLD_SEC=5
MAX_BACKOFF_SEC=60
MAX_FAST_FAILS=10
RESET_RUNTIME_SEC=30
SENTINEL_FILE=/run/chimebox-bedtime

backoff=1
fast_fails=0

while :; do
    if [ -f "${SENTINEL_FILE}" ]; then
        echo "chimebox: bedtime sentinel present; idling without BasiliskII" \
            >> "${LOG_FILE}"
        # Sleep long enough that we don't spam the log, short enough that
        # `wake-up.sh` (which removes the sentinel) feels responsive.
        sleep 10
        continue
    fi

    started=$(date +%s)
    BasiliskII >> "${LOG_FILE}" 2>&1
    rc=$?
    runtime=$(( $(date +%s) - started ))

    echo "chimebox: BasiliskII exited rc=${rc} after ${runtime}s" \
        >> "${LOG_FILE}"

    if [ "${runtime}" -lt "${CRASH_THRESHOLD_SEC}" ]; then
        fast_fails=$((fast_fails + 1))
        if [ "${fast_fails}" -ge "${MAX_FAST_FAILS}" ]; then
            echo "chimebox: ${fast_fails} fast failures in a row;" \
                 "giving up so getty can take over" >> "${LOG_FILE}"
            exit 1
        fi
        echo "chimebox: short run; backing off ${backoff}s" \
            >> "${LOG_FILE}"
        sleep "${backoff}"
        backoff=$(( backoff * 2 ))
        if [ "${backoff}" -gt "${MAX_BACKOFF_SEC}" ]; then
            backoff="${MAX_BACKOFF_SEC}"
        fi
    else
        # Long enough that we treat this as a real session
        # (boot + use + Mac OS shutdown). Reset the backoff state.
        if [ "${runtime}" -ge "${RESET_RUNTIME_SEC}" ]; then
            fast_fails=0
            backoff=1
        fi
        # Brief pause so the user sees that "shutdown happened" --
        # screen stays black for a moment before the Mac comes back.
        sleep 1
    fi
done
