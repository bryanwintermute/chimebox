# {{ ansible_managed }}
# chimebox BasiliskII prefs file.
#
# BasiliskII reads this from ~/.config/BasiliskII/prefs by default.
# Note: BasiliskII may rewrite this file on exit if 'nogui' allowed any
# settings to change. Ansible re-asserts these values on every run, so
# any drift is corrected on the next provisioning.
#
# Key reference: see basilisk2 source / GUI -- key names come from the
# C++ prefs framework. The 'screen' format is "win/W/H" or "win/W/H/D"
# (D = color depth in bits, optional). 'modelid' is Gestalt ID minus 6;
# 14 = Quadra 650.

rom {{ chimebox_runtime_dir }}/{{ chimebox_rom_filename }}
disk {{ chimebox_runtime_dir }}/{{ chimebox_system_disk_filename }}
{# Library disk is optional. The role checks for its presence and sets
   chimebox_library_disk_present accordingly; this stanza is only emitted
   if InfiniteHD.dsk has been pushed to the runtime dir. #}
{% if chimebox_library_disk_present | default(false) %}
disk {{ chimebox_runtime_dir }}/{{ chimebox_library_disk_filename }}
{% endif %}
screen win/{{ chimebox_screen_width }}/{{ chimebox_screen_height }}
ramsize {{ chimebox_ram_mb * 1024 * 1024 }}
modelid {{ chimebox_modelid }}
cpu {{ chimebox_cpu }}
fpu {{ 'true' if chimebox_fpu else 'false' }}

# JIT on aarch64: BasiliskII's JIT was historically x86-only. Modern
# aarch64 builds either fall back to interpreter or have buggy behavior
# when JIT is requested. Default OFF on Pi; the interpreter is fast
# enough on Pi 5 for our workload (Mac OS 8.1 is single-digit-MHz era).
jit false
jitfpu false
jitdebug false
jitcachesize 0
jitlazyflush false
jitinline false

# UI / behavior
nogui true
nocdrom true
nosound false
noclipconversion false
# idlewait: when true, BasiliskII sleeps when the emulated Mac is idle.
# That sounds nice for power but introduces noticeable cursor stutter
# (sleep -> wake on input -> redraw). Default OFF for chimebox; the
# Pi has plenty of headroom and we'd rather have smooth interaction.
idlewait false
# init_grab: when true, BasiliskII captures the host pointer inside its
# window and uses relative-motion deltas. When false, it uses absolute
# coordinates from X.
#
#   true  -- best for physical mouse / kiosk use; cursor cannot leave
#            the Mac screen. Required for the pillarbox display profile
#            (otherwise pillar-area motion outside the B2 window
#            doesn't update the Mac cursor).
#   false -- required for PiKVM/VNC (which send absolute HID coords).
#            Display profile must be matched (X canvas size == B2
#            window size) to avoid offset.
init_grab {{ 'true' if chimebox_init_grab else 'false' }}
swap_opt_cmd false
keyboardtype 5
mousewheelmode 1
mousewheellines 3
# SDL renderer: 'software' is recommended by BasiliskII --help as
# possibly faster for emulator workloads. The 'auto' default can pick
# a hardware-accelerated renderer that adds latency for the small
# blits we do. Worth keeping on 'software' until proven otherwise.
sdlrender software

# Disabled hardware
seriala
serialb
ether
udptunnel false
extfs

# Defaults
bootdrive 0
bootdriver 0
frameskip 0
displaycolordepth 0
sound_buffer 0
delay 0
yearofs 0
dayofs 0
