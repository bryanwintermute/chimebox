#!/bin/bash
# {{ ansible_managed }}
# /usr/local/sbin/chimebox-audio-init
#
# Configures ALSA default sink + boot-time volume for the chimebox
# kiosk. Runs once on boot via chimebox-audio-init.service.
#
# Behavior:
#   1. Resolve which ALSA card to use, based on
#      chimebox_audio_card (or "auto").
#   2. Write /etc/asound.conf so subsequent ALSA opens (including
#      SDL2/BasiliskII) get the right default.
#   3. Set the master volume on the chosen card to
#      chimebox_audio_default_volume_percent.
#   4. Persist via 'alsactl store' so the alsa-utils-shipped
#      restore service can replay the state on subsequent boots.
#
# Designed to fail soft: if the configured card isn't present at
# boot, we log a clear warning and either auto-fall-back or leave
# ALSA on its built-in default. The kiosk keeps working; the kid
# just might not hear audio until the operator plugs the right
# device in.

set -u

LOG_TAG="chimebox-audio-init"
log() {
    logger -t "${LOG_TAG}" -- "$*"
    echo "${LOG_TAG}: $*" >&2
}

CARD="{{ chimebox_audio_card }}"
MASTER_CONTROL="{{ chimebox_audio_master_control }}"
VOLUME_PCT="{{ chimebox_audio_default_volume_percent }}"
{% raw %}
ASOUND_CONF="/etc/asound.conf"

# --- Step 1: list available cards ---

if [ ! -r /proc/asound/cards ]; then
    log "no /proc/asound/cards; ALSA not loaded?"
    exit 0
fi

# /proc/asound/cards format:
#   0 [vc4hdmi0       ]: vc4-hdmi - vc4-hdmi-0
#                        vc4-hdmi-0
# We grep the indented bracket lines.
mapfile -t CARDS < <(awk '/^[ ]*[0-9]+ \[/ {
    gsub(/[\[\]]/,"",$2); print $1 "=" $2
}' /proc/asound/cards)

if [ "${#CARDS[@]}" -eq 0 ]; then
    log "no ALSA cards present; nothing to configure"
    exit 0
fi

log "detected ALSA cards: ${CARDS[*]}"

# --- Step 2: resolve CARD ---

declare -A IDX_TO_NAME NAME_TO_IDX
for entry in "${CARDS[@]}"; do
    idx="${entry%%=*}"
    name="${entry##*=}"
    IDX_TO_NAME["${idx}"]="${name}"
    NAME_TO_IDX["${name}"]="${idx}"
done

is_usb_audio_card() {
    # snd_usb_audio module name shows up in /proc/asound/modules:
    #   0 vc4
    #   1 vc4
    #   2 snd_usb_audio
    local idx="$1"
    if [ -r /proc/asound/modules ]; then
        awk -v i="${idx}" '$1==i {print $2}' /proc/asound/modules \
            | grep -q "^snd_usb_audio$"
    fi
}

chosen_idx=""
chosen_name=""

if [ "${CARD}" = "auto" ]; then
    # Prefer first USB audio card; fall back to card 0.
    for entry in "${CARDS[@]}"; do
        idx="${entry%%=*}"
        if is_usb_audio_card "${idx}"; then
            chosen_idx="${idx}"
            chosen_name="${IDX_TO_NAME[${idx}]}"
            log "auto: selected USB audio card ${idx} (${chosen_name})"
            break
        fi
    done
    if [ -z "${chosen_idx}" ]; then
        chosen_idx="0"
        chosen_name="${IDX_TO_NAME[0]:-}"
        log "auto: no USB audio; falling back to card 0 (${chosen_name})"
    fi
elif [[ "${CARD}" =~ ^[0-9]+$ ]]; then
    chosen_idx="${CARD}"
    chosen_name="${IDX_TO_NAME[${CARD}]:-}"
    if [ -z "${chosen_name}" ]; then
        log "warning: card index ${CARD} not present; using ALSA built-in default"
        exit 0
    fi
    log "selected card by index: ${chosen_idx} (${chosen_name})"
else
    # Card name; look up index.
    chosen_idx="${NAME_TO_IDX[${CARD}]:-}"
    if [ -z "${chosen_idx}" ]; then
        log "warning: card '${CARD}' not present at boot; using ALSA built-in default"
        exit 0
    fi
    chosen_name="${CARD}"
    log "selected card by name: ${chosen_name} (index ${chosen_idx})"
fi

# --- Step 3: write /etc/asound.conf ---
#
# We route by card NAME (hw:CARDNAME), not index, because index
# can shift when USB devices plug/unplug. ALSA resolves the name
# to whatever index that card currently holds.

NEW_CONF=$(cat <<EOF
# Managed by chimebox-audio-init (regenerated on each boot).
# Do not edit; set chimebox_audio_card in host_vars instead.

pcm.!default {
    type plug
    slave.pcm "hw:${chosen_name},0"
}

ctl.!default {
    type hw
    card "${chosen_name}"
}
EOF
)

if [ ! -f "${ASOUND_CONF}" ] || ! diff -q <(echo "${NEW_CONF}") "${ASOUND_CONF}" >/dev/null 2>&1; then
    echo "${NEW_CONF}" > "${ASOUND_CONF}.tmp"
    mv "${ASOUND_CONF}.tmp" "${ASOUND_CONF}"
    chmod 0644 "${ASOUND_CONF}"
    log "wrote ${ASOUND_CONF} (default sink -> hw:${chosen_name})"
else
    log "${ASOUND_CONF} already correct; no change"
fi

# --- Step 4: set master volume ---

if [ -z "${MASTER_CONTROL}" ]; then
    log "no master control configured for this host; skipping volume set"
elif amixer -c "${chosen_idx}" sget "${MASTER_CONTROL}" >/dev/null 2>&1; then
    if amixer -c "${chosen_idx}" -q sset "${MASTER_CONTROL}" "${VOLUME_PCT}%" unmute; then
        log "set ${chosen_name}:${MASTER_CONTROL} to ${VOLUME_PCT}%"
    else
        log "warning: amixer sset failed for ${chosen_name}:${MASTER_CONTROL}"
    fi
else
    log "card ${chosen_name} has no '${MASTER_CONTROL}' control; volume set skipped (likely an HDMI card with no software mixer)"
fi

# --- Step 5: persist for the alsa-state restore service ---

if command -v alsactl >/dev/null 2>&1; then
    if alsactl store 2>&1 | logger -t "${LOG_TAG}"; then
        log "alsactl store: persisted current mixer state"
    fi
fi

exit 0
{% endraw %}
