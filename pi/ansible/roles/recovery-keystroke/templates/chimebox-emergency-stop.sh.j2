#!/bin/bash
# {{ ansible_managed }}
# /usr/local/sbin/chimebox-emergency-stop
#
# Stop the entire kiosk -- arms the bedtime sentinel, SIGTERMs
# BasiliskII for graceful Mac shutdown, then stops getty so X
# fully tears down. Equivalent to scripts/bedtime.sh 0 from a
# workstation, but invokable from inside the kiosk via xbindkeys.
#
# This is the "I really need it off NOW" key, distinct from the
# force-reset key. Off by default; enable in host_vars via
# chimebox_recovery_emergency_stop_enabled.

set -u

LOG_TAG="chimebox-emergency-stop"
log() {
    logger -t "${LOG_TAG}" -- "$*"
    echo "${LOG_TAG}: $*" >&2
}

log "emergency stop initiated"

# Cleanly shut down the emulated Mac first so we don't leave System.dsk
# dirty. chimebox-stop-mac arms the bedtime sentinel, SIGTERMs BasiliskII,
# auto-confirms Mac OS's "Shut Down" dialog, and waits for a clean unmount
# (a few seconds). --for-shutdown leaves the sentinel armed so the kiosk
# stays down until wake-up.sh. Falls back to a bare SIGTERM if the
# primitive isn't installed (older images).
if [ -x /usr/local/sbin/chimebox-stop-mac ]; then
    /usr/local/sbin/chimebox-stop-mac --for-shutdown || true
else
    touch /run/chimebox-bedtime
    bpid="$(pgrep -x BasiliskII | head -1 || true)"
    if [ -n "${bpid}" ]; then
        kill -TERM "${bpid}" 2>/dev/null || true
    fi
fi

# Stop getty so X tears down (matches scripts/bedtime.sh phase 3).
systemctl stop getty@tty1.service 2>/dev/null || true
pkill -u {{ chimebox_user }} 2>/dev/null || true

log "kiosk stopped; run wake-up.sh to restart"
exit 0
